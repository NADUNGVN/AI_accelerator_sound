{
  "model_name": "kv260_audio_net_ds1d",
  "width_mult": 1.0,
  "dropout": 0.20,
  "pool_type": "avgmax",
  "batch_size": 128,
  "accum_steps": 1,
  "epochs": 50,
  "lr": 0.001,
  "optimizer": "adamw",
  "weight_decay": 0.0005,
  "num_workers": 0,
  "sample_rate": 16000,

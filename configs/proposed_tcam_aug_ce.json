{
  "model_name": "tcam1dcnn",
  "batch_size": 100,
  "accum_steps": 1,
  "epochs": 120,
  "lr": 3e-4,
  "optimizer": "adamw",
  "weight_decay": 1e-4,
  "num_workers": 0,
  "sample_rate": 16000,
  "clip_seconds": 4.0,
  "frame_length": 8000,
  "frame_hop": 4000,
  "frames_per_clip": 15,
  "drop_silent_tail_frames": false,
  "cycles": 4,
  "seed": 83,
  "protocol": "source_group_9_1",
  "source_group_split_algorithm": "fsid_classid_balanced_v1",
  "amp": true,
  "gradient_clip": 5.0,
  "adam_eps": 1e-8,
  "loss": "crossentropy",
  "label_smoothing": 0.03,
  "class_weighting": "balanced",
  "augment": {
    "enabled": true,
    "gain_db": 6.0,
    "noise_prob": 0.25,
    "noise_snr_db_min": 20.0,
    "noise_snr_db_max": 35.0,
    "shift_prob": 0.50,
    "shift_max_fraction": 0.10,
    "polarity_prob": 0.15,
    "time_mask_prob": 0.25,
    "time_mask_max_fraction": 0.10
  }
}

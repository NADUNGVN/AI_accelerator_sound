{
  "dataset": "speech_commands",
  "protocol": "speech_commands_v2_official12",
  "model_name": "ds_conv2d_h1_pyramid",
  "width_mult": 1.0,
  "dropout": 0.25,
  "pool_type": "pyramid_avgmax",
  "pool_bins": [1, 2, 4],
  "stem_type": "single",
  "deployment_budget": {
    "max_params": 300000,
    "max_macs_per_clip": 300000000,
    "flops_equivalent_convention": "FLOPs = 2 * MACs"
  },
  "batch_size": 64,
  "accum_steps": 1,
  "epochs": 30,
  "lr": 0.001,
  "optimizer": "adamw",
  "weight_decay": 0.0008,
  "num_workers": 6,
  "sample_rate": 16000,
  "clip_seconds": 1.0,
  "frame_length": 16000,
  "frame_hop": 16000,
  "frames_per_clip": 1,
  "drop_silent_tail_frames": false,
  "eval_drop_silent_tail_frames": false,
  "cycles": 3,
  "seed": 83,
  "amp": true,
  "gradient_clip": 5.0,
  "adam_eps": 1e-8,
  "loss": "crossentropy",
  "label_smoothing": 0.04,
  "class_weighting": "balanced",
  "weighted_sampler": {
    "enabled": false
  },
  "mixup": {
    "enabled": true,
    "alpha": 0.2,
    "prob": 0.5
  },
  "ema": {
    "enabled": true,
    "decay": 0.995,
    "use_for_validation": true
  },
  "augment": {
    "enabled": true,
    "gain_db": 3.0,
    "noise_prob": 0.15,
    "noise_snr_db_min": 20.0,
    "noise_snr_db_max": 38.0,
    "shift_prob": 0.5,
    "shift_max_fraction": 0.08,
    "polarity_prob": 0.0,
    "time_mask_prob": 0.12,
    "time_mask_max_fraction": 0.06
  },
  "notes": {
    "role": "Phase 1 Speech Commands deployable waveform-student config",
    "protocol": "Official train/validation/test split, 12 labels: 10 commands plus silence and unknown",
    "metric": "Validation-selected test accuracy; macro-F1 secondary after analysis support is stable",
    "status": "Loader/config smoke first; no paper accuracy claim yet"
  }
}

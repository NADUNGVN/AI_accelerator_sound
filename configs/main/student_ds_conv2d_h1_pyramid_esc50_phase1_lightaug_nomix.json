{
  "dataset": "esc50",
  "protocol": "esc50_3_1_1_foldk_valnext_v1",
  "model_name": "ds_conv2d_h1_pyramid",
  "width_mult": 1.0,
  "dropout": 0.15,
  "pool_type": "pyramid_avgmax",
  "pool_bins": [1, 2, 4],
  "stem_type": "single",
  "deployment_budget": {
    "max_params": 300000,
    "max_macs_per_clip": 300000000,
    "flops_equivalent_convention": "FLOPs = 2 * MACs"
  },
  "batch_size": 64,
  "accum_steps": 1,
  "epochs": 120,
  "lr": 0.0005,
  "optimizer": "adamw",
  "weight_decay": 0.0002,
  "num_workers": 6,
  "sample_rate": 16000,
  "clip_seconds": 5.0,
  "frame_length": 80000,
  "frame_hop": 80000,
  "frames_per_clip": 1,
  "drop_silent_tail_frames": false,
  "eval_drop_silent_tail_frames": false,
  "cycles": 4,
  "seed": 83,
  "amp": true,
  "gradient_clip": 5.0,
  "adam_eps": 1e-8,
  "loss": "crossentropy",
  "label_smoothing": 0.02,
  "class_weighting": "none",
  "weighted_sampler": {
    "enabled": false
  },
  "mixup": {
    "enabled": false,
    "alpha": 0.2,
    "prob": 0.0
  },
  "ema": {
    "enabled": false,
    "decay": 0.995,
    "use_for_validation": false
  },
  "augment": {
    "enabled": true,
    "gain_db": 2.0,
    "noise_prob": 0.1,
    "noise_snr_db_min": 26.0,
    "noise_snr_db_max": 42.0,
    "shift_prob": 0.3,
    "shift_max_fraction": 0.04,
    "polarity_prob": 0.0,
    "time_mask_prob": 0.08,
    "time_mask_max_fraction": 0.025
  },
  "notes": {
    "role": "ESC-50 Phase 1 light augmentation candidate",
    "purpose": "Start from the successful no-augment sanity run and add only mild waveform augmentation plus light label smoothing to reduce overfit without reintroducing mixup/EMA collapse.",
    "interpretation": "Use this as the next fold-1 gate. Promote to the ESC-50 Phase 1 config only if validation-selected and final test improve over the no-augment 35-37% baseline."
  }
}

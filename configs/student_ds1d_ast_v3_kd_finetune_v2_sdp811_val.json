{
  "model_name": "kv260_audio_net_ds1d",
  "width_mult": 1.0,
  "dropout": 0.25,
  "pool_type": "pyramid_avgmax",
  "pool_bins": [1, 2, 4],
  "stem_type": "single",
  "deployment_budget": {
    "max_params": 300000,
    "max_macs_per_clip": 300000000,
    "flops_equivalent_convention": "FLOPs = 2 * MACs"
  },
  "initial_checkpoint": {
    "enabled": true,
    "template": "experiments/server8000_student_noteacher_sdp811_f1_50ep/fold_{fold}/checkpoints/tcam_fold_{fold}_best.pt",
    "strict": true
  },
  "batch_size": 64,
  "accum_steps": 1,
  "epochs": 30,
  "lr": 0.0002,
  "optimizer": "adamw",
  "weight_decay": 0.0008,
  "num_workers": 8,
  "sample_rate": 16000,
  "clip_seconds": 4.0,
  "frame_length": 64000,
  "frame_hop": 64000,
  "frames_per_clip": 1,
  "drop_silent_tail_frames": false,
  "eval_drop_silent_tail_frames": false,
  "cycles": 4,
  "seed": 83,
  "protocol": "source_group_8_1_1",
  "source_group_split_algorithm": "fsid_classid_balanced_v1",
  "amp": true,
  "gradient_clip": 5.0,
  "adam_eps": 1e-8,
  "loss": "crossentropy",
  "label_smoothing": 0.02,
  "class_weighting": "balanced",
  "class_weight_multipliers": [1.10, 1.30, 1.00, 1.10, 1.10, 1.20, 1.00, 1.40, 1.00, 1.05],
  "mixup": {
    "enabled": true,
    "alpha": 0.20,
    "prob": 0.40
  },
  "distillation": {
    "enabled": true,
    "mode": "cached_logits",
    "teacher_logits_template": "experiments/ast_teacher_logits_v3_sdp811/fold_{fold}/teacher_logits.pt",
    "weight": 0.35,
    "temperature": 2.5,
    "protect_classes": [0, 4, 5, 7],
    "require_teacher_correct": false,
    "confidence_threshold": 0.0,
    "apply_to_mixup": true
  },
  "ema": {
    "enabled": true,
    "decay": 0.995,
    "use_for_validation": true
  },
  "early_stopping": {
    "enabled": true,
    "monitor": "val_clip_acc",
    "mode": "max",
    "warmup_epochs": 8,
    "patience": 10,
    "min_delta": 0.001
  },
  "augment": {
    "enabled": true,
    "gain_db": 4.0,
    "noise_prob": 0.20,
    "noise_snr_db_min": 22.0,
    "noise_snr_db_max": 40.0,
    "shift_prob": 0.45,
    "shift_max_fraction": 0.06,
    "polarity_prob": 0.08,
    "time_mask_prob": 0.14,
    "time_mask_max_fraction": 0.05
  }
}

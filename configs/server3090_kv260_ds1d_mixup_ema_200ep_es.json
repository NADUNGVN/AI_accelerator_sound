{
  "model_name": "kv260_audio_net_ds1d",
  "width_mult": 1.0,
  "dropout": 0.20,
  "pool_type": "avgmax",
  "stem_type": "single",
  "deployment_budget": {
    "max_params": 300000,
    "max_macs_per_clip": 300000000,
    "flops_equivalent_convention": "FLOPs = 2 * MACs"
  },
  "batch_size": 128,
  "accum_steps": 1,
  "epochs": 200,
  "lr": 0.001,
  "optimizer": "adamw",
  "weight_decay": 0.0007,
  "num_workers": 0,
  "sample_rate": 16000,
  "clip_seconds": 4.0,
  "frame_length": 64000,
  "frame_hop": 64000,
  "frames_per_clip": 1,
  "drop_silent_tail_frames": false,
  "eval_drop_silent_tail_frames": false,
  "cycles": 4,
  "seed": 83,
  "protocol": "source_group_8_1_1",
  "source_group_split_algorithm": "fsid_classid_balanced_v1",
  "amp": true,
  "gradient_clip": 5.0,
  "adam_eps": 1e-8,
  "loss": "crossentropy",
  "label_smoothing": 0.04,
  "class_weighting": "balanced",
  "class_weight_multipliers": [1.10, 1.45, 1.00, 1.15, 1.00, 1.00, 1.00, 1.80, 1.00, 1.00],
  "weighted_sampler": {
    "enabled": true,
    "class_multipliers": [1.05, 1.40, 1.00, 1.10, 1.00, 1.00, 1.00, 1.50, 1.00, 1.00]
  },
  "mixup": {
    "enabled": true,
    "alpha": 0.20,
    "prob": 0.80
  },
  "ema": {
    "enabled": true,
    "decay": 0.995,
    "use_for_validation": true
  },
  "early_stopping": {
    "enabled": true,
    "monitor": "val_clip_acc",
    "mode": "max",
    "warmup_epochs": 80,
    "patience": 35,
    "min_delta": 0.001
  },
  "augment": {
    "enabled": true,
    "gain_db": 5.0,
    "noise_prob": 0.25,
    "noise_snr_db_min": 20.0,
    "noise_snr_db_max": 38.0,
    "shift_prob": 0.50,
    "shift_max_fraction": 0.08,
    "polarity_prob": 0.10,
    "time_mask_prob": 0.20,
    "time_mask_max_fraction": 0.06
  }
}
